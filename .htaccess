RewriteEngine On

# Canonical URLs zonder .html
RewriteCond %{THE_REQUEST} \s/+(index|dashboard|cashier)\.html[\s?] [NC]
RewriteRule ^ %1 [R=301,L]

# Mooie routes -> bestaande HTML bestanden
RewriteRule ^$ index.html [L]
RewriteRule ^index/?$ index.html [L]
RewriteRule ^dashboard/?$ dashboard.html [L]
RewriteRule ^cashier/?$ cashier.html [L]

